# ---- Stillwater Command Center — Vercel environment variables ----
# Set these in Vercel: Project → Settings → Environment Variables.

# Supabase Postgres connection (Transaction pooler).
# Supabase dashboard → Project Settings → Database → Connection string → "Transaction".
# Replace [YOUR-DB-PASSWORD] with your database password.
DATABASE_URL=postgresql://postgres.pqhejgzbmhhaxaraklgl:[YOUR-DB-PASSWORD]@aws-0-us-west-2.pooler.supabase.com:6543/postgres

# Password you type to sign in to the console (choose anything).
CC_PASSWORD=change-me

# Long random string used to sign session tokens (e.g. `openssl rand -hex 32`).
SESSION_SECRET=change-me-to-a-long-random-string

# OPTIONAL — Meta (Facebook) long-lived access token to enable live Ads on the web build.
# Leave unset and the Ads view simply shows no data (everything else works).
# META_ACCESS_TOKEN=
